<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">


        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/applogo"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_logo_circle"
            android:padding="8dp"
            android:layout_marginBottom="20dp"/>


        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NariGuard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- Version -->
        <TextView
            android:id="@+id/appVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Description -->
        <TextView
            android:id="@+id/aboutText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NariGuard is a women’s safety application designed to help users in emergency situations. It provides features like SOS alerts, live location sharing, emergency contacts, and quick access to help.\n\nThe main goal of NariGuard is to ensure safety, confidence, and quick support for women anytime and anywhere."
            android:textSize="16sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="20dp"/>

        <!-- Developer Info -->
        <TextView
            android:id="@+id/developerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Developed by: Nisha Potkule"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/collegeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B.Tech Computer Science Engineering"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/contactText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact: nishapotkule@gmail.com"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
