<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F1A"
    android:padding="16dp">

    <!-- TITLE -->
    <TextView
        android:text="Voice Memos"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- TIMER -->
    <TextView
        android:id="@+id/tvTimer"
        android:text="00:00:00"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Ready to record"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- WAVE ICON -->
    <ImageView
        android:id="@+id/ivWave"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:src="@drawable/wave"
        app:tint="#2979FF"/>

    <!-- RECORD BUTTON -->
    <ImageButton
        android:id="@+id/btnRecord"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:background="@drawable/record_button_background"
        android:src="@drawable/mic"
        android:scaleType="centerInside"
        android:contentDescription="Record Button"
        app:tint="#FFFFFF" />

    <!-- RECENT RECORDINGS HEADER -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical">

        <TextView
            android:text="Recent Recordings"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="See All"
            android:textSize="14sp"
            android:textColor="#2979FF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- RECENT RECORDINGS LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVoiceRecords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:scrollbars="vertical"/>
</LinearLayout>