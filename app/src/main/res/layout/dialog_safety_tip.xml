<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/tvTopicTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Safety Topic"
            android:textColor="#FFD6DE"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAFETY PROTOCOL"
            android:textColor="#8E7B80"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <!-- DYNAMIC CONTENT CONTAINER -->
        <LinearLayout
            android:id="@+id/layoutTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- BUTTON -->
        <TextView
            android:id="@+id/btnAcknowledge"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/protocol_button_bg"
            android:gravity="center"
            android:text="Acknowledge"
            android:textColor="#4A0014"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>